# Host ports (when other services already use defaults)
# PostgreSQL host: 5433, Redis host: 6380, MinIO host: 9100/9101
POSTGRES_USER=ams
POSTGRES_PASSWORD=ams_password
POSTGRES_DB=avatar_management
DATABASE_URL=postgresql://ams:ams_password@postgres:5432/avatar_management

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=avatars
MINIO_USE_SSL=false

# API
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_PORT=3000

# Frontend (browser-accessible URLs)
NEXT_PUBLIC_API_URL=http://localhost:4003
